DefineConstant[
	mm = 1e-3,
	Flag_SpecifyMeshSize = {0, Name StrCat[INPUT_MESH, "04User defined surface mesh sizes"],Choices {0, 1}}
];
If(Flag_SpecifyMeshSize)
	DefineConstant[
		magnet_msf = {0.741, Name StrCat[INPUT_MESH, "05Mesh Size/Magnet [mm]"],Min 0.0741, Max 7.41, Step 0.1,Visible Flag_SpecifyMeshSize},
		rotor_lamination_msf = {0.838, Name StrCat[INPUT_MESH, "05Mesh Size/Rotor Lamination [mm]"],Min 0.0838, Max 8.379999999999999, Step 0.1,Visible Flag_SpecifyMeshSize},
		rotor_airgap_msf = {0.158, Name StrCat[INPUT_MESH, "05Mesh Size/Rotor Airgap [mm]"],Min 0.0158, Max 1.58, Step 0.1,Visible Flag_SpecifyMeshSize},
		rotor_air_msf = {0.158, Name StrCat[INPUT_MESH, "05Mesh Size/Rotor Air [mm]"],Min 0.0158, Max 1.58, Step 0.1,Visible Flag_SpecifyMeshSize},
		stator_slot_msf = {1.913, Name StrCat[INPUT_MESH, "05Mesh Size/Stator Slot [mm]"],Min 0.1913, Max 19.13, Step 0.1,Visible Flag_SpecifyMeshSize},
		stator_lamination_msf = {2.123, Name StrCat[INPUT_MESH, "05Mesh Size/Stator Lamination [mm]"],Min 0.21230000000000002, Max 21.230000000000004, Step 0.1,Visible Flag_SpecifyMeshSize},
		stator_airgap_msf = {0.159, Name StrCat[INPUT_MESH, "05Mesh Size/Stator Airgap [mm]"],Min 0.0159, Max 1.59, Step 0.1,Visible Flag_SpecifyMeshSize},
		stator_air_msf = {0.159, Name StrCat[INPUT_MESH, "05Mesh Size/Stator Air [mm]"],Min 0.0159, Max 1.59, Step 0.1,Visible Flag_SpecifyMeshSize}
	];
	MeshSize { PointsOf {Surface{ 6,12 };} } = magnet_msf*mm;
	MeshSize { PointsOf {Surface{ 14 };} } = rotor_lamination_msf*mm;
	MeshSize { PointsOf {Surface{ 31 };} } = rotor_airgap_msf*mm;
	MeshSize { PointsOf {Surface{ 31 };} } = rotor_air_msf*mm;
	MeshSize { PointsOf {Surface{ 17,24,25,26,27,28 };} } = stator_slot_msf*mm;
	MeshSize { PointsOf {Surface{ 16,19,20,21,22,23 };} } = stator_lamination_msf*mm;
	MeshSize { PointsOf {Surface{ 30 };} } = stator_airgap_msf*mm;
	MeshSize { PointsOf {Surface{ 30 };} } = stator_air_msf*mm;
EndIf

// Mesh operations

// Do not switch mesh algorithm on failure, because this led to mesh errors in the past.
Mesh.AlgorithmSwitchOnFailure = 0;DefineConstant[Flag_CompoundMesh = {0, Name StrCat[INPUT_MESH, "Compound Mesh"], Choices {0,1}, Help "Use Compound Mesh to ignore lines between segments while meshing.",Visible Flag_ExpertMode}];
If (Flag_CompoundMesh)
Compound Surface{16,19,20,21,22,23}; // stator domainLam
EndIf // (Flag_CompoundMesh)

// Add Periodic Mesh to model symmetry boundary-lines
primaryLines = {180,160,253,250,247,168};
secondaryLines = {181,163,255,252,249,230};
Periodic Curve{secondaryLines[]} = {primaryLines[]} Rotate {{0,0,1}, {0,0,0}, 2*Pi/8};

// Add mesh size setting for Movingband lines
DefineConstant[
	NbrMbSegments = {3370.0, Name StrCat[INPUT_MESH, "Number of Rotor Movingband Segments"],Max 3370.0, Min 180, Step 10, Help "Set the number of mesh segments on the interface between rotor/statorairgap and movingband. Value represents number of segments on whole circle.", Visible Flag_ExpertMode},
	r_MB_R = 0.08049999999999999
];
MB_LinesR = {254,256,257,258,259,260,261,262};
MeshSize{ PointsOf{Line{MB_LinesR[]};}} = 2*Pi*r_MB_R/NbrMbSegments;

MB_LinesS = {251};
MeshSize{ PointsOf{Line{MB_LinesS[]};}} = 2*Pi*0.08064999999999999/NbrMbSegments;

Mesh.SurfaceFaces = 0; // don't show mesh faces (only edges)

Hide {:}
Recursive Show { Physical Surface{:}; }
Recursive Show { Physical Curve{:}; }
Geometry.PointSize = 3.0;

// Create boundary lines for moving rotor contour plot
rotorBndLines[] = Boundary{ Physical Surface{ 17,19 }; };
rotorBndLines[] += CombinedBoundary{ Physical Surface{ 15 }; };
rotorBndLines[] += CombinedBoundary{ Physical Surface{ 31 }; };
statorBndLines[] = Boundary{ Physical Surface{ 3,4,5,14,21,22,23,24,25,26,27,29,30 }; };
Physical Line("DomainPlotMovingGeo",32) = {rotorBndLines[], statorBndLines[]};
